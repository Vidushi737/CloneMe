# CloneMe Environment Configuration

# Backend Settings
PROJECT_NAME=CloneMe
DEBUG=True
API_V1_STR=/api/v1

# Security
JWT_SECRET=supersecretjwtkeyforclonemedigitaltwinplatformdevelopmentonly123!
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database Settings
# Local development uses SQLite by default. Docker-compose uses PostgreSQL.
DATABASE_URL=sqlite:///./cloneme.db
POSTGRES_USER=cloneme
POSTGRES_PASSWORD=cloneme_secure_pass
POSTGRES_DB=cloneme
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Chroma Vector Database Settings
# Local sqlite/chromadb path
CHROMA_DB_DIR=./chromadb_store
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# AI Layer Settings
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# CORS Settings
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]
